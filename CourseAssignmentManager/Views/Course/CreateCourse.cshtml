<div class="container">
    <div class="page-header">
        <div>
            <h1>Create New Course</h1>
            <p>Add a new course for your students</p>
        </div>
        <a href="/Course/CourseList" class="btn btn-outline">← Back to Courses</a>
    </div>

    <div style="max-width: 580px;">
        <div class="card">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-error">@ViewBag.Error</div>
            }

            <form method="post" action="/Course/CreateCourse">
                <div class="form-group">
                    <label>Course Name</label>
                    <input type="text" name="courseName" class="form-control"
                           placeholder="e.g. Database Systems, Web Development" required />
                </div>

                <div class="form-group">
                    <label>Description</label>
                    <textarea name="description" class="form-control"
                              placeholder="Briefly describe what this course covers..." rows="4"></textarea>
                </div>

                <div style="display:flex; gap:10px; margin-top:1.5rem;">
                    <button type="submit" class="btn btn-primary">Create Course</button>
                    <a href="/Course/CourseList" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>