@{
    var courses = ViewBag.Courses as List<CourseAssignmentManager.Models.Course> ?? new();
}

<div class="container">
    <div class="page-header">
        <div>
            <h1>Create New Assignment</h1>
            <p>Post a new assignment for your students</p>
        </div>
        <a href="/Assignment/AssignmentList" class="btn btn-outline">← Back to Assignments</a>
    </div>

    <div style="max-width: 580px;">
        <div class="card">
            @if (courses.Count == 0)
            {
                <div class="alert alert-info">
                    <p style="margin-bottom:10px;">You need to create a course first before adding assignments.</p>
                    <a href="/Course/CreateCourse" class="btn btn-primary btn-sm">Create Course</a>
                </div>
            }
            else
            {
                <form method="post" action="/Assignment/CreateAssignment">
                    <div class="form-group">
                        <label>Assignment Title</label>
                        <input type="text" name="assignmentName" class="form-control"
                               placeholder="e.g. SQL Practice Exercise, Final Project" required />
                    </div>

                    <div class="form-group">
                        <label>Description</label>
                        <textarea name="description" class="form-control"
                                  placeholder="Describe the assignment requirements..." rows="4"></textarea>
                    </div>

                    <div class="form-group">
                        <label>Select Course</label>
                        <select name="courseId" class="form-control" required>
                            <option value="">-- Select a course --</option>
                            @foreach (var course in courses)
                            {
                                <option value="@course.CourseId">@course.CourseName</option>
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Due Date</label>
                        <input type="datetime-local" name="dueDate" class="form-control" required />
                    </div>

                    <div style="display:flex; gap:10px; margin-top:1.5rem;">
                        <button type="submit" class="btn btn-primary">Create Assignment</button>
                        <a href="/Assignment/AssignmentList" class="btn btn-outline">Cancel</a>
                    </div>
                </form>
            }
        </div>
    </div>
</div>