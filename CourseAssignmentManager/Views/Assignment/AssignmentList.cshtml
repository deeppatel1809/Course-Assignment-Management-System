@model List<CourseAssignmentManager.Models.Assignment>
@{
    var role = Context.Session.GetString("UserRole");
    var courses = ViewBag.Courses as List<CourseAssignmentManager.Models.Course> ?? new List<CourseAssignmentManager.Models.Course>();
    var mySubmissions = ViewBag.MySubmissions as List<int> ?? new List<int>();
}

<div class="container">
    <div class="page-header">
        <div>
            <h1>Assignments</h1>
            <p>@(role == "Teacher" ? "Manage your assignments" : "View and submit your assignments")</p>
        </div>
        @if (role == "Teacher")
        {
            <a href="/Assignment/CreateAssignment" class="btn btn-primary">+ Create Assignment</a>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="card">
        @if (Model.Count == 0)
        {
            <div class="empty-state">
                <h3>No assignments found</h3>
                @if (role == "Teacher")
                {
                    <p>Create your first assignment for students</p>
                    <a href="/Assignment/CreateAssignment" class="btn btn-primary">Create Assignment</a>
                }
                else
                {
                    <p>No assignments have been posted yet</p>
                }
            </div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>Assignment Name</th>
                        <th>Course</th>
                        <th>Description</th>
                        <th>Due Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var assignment in Model)
                    {
                        var course = courses.FirstOrDefault(c => c.CourseId == assignment.CourseId);
                        bool isOverdue = assignment.DueDate < DateTime.UtcNow;
                        bool submitted = mySubmissions.Contains(assignment.AssignmentId);

                        <tr>
                            <td><strong>@assignment.AssignmentName</strong></td>
                            <td>
                                <span class="badge badge-purple">@(course?.CourseName ?? "Unknown")</span>
                            </td>
                            <td style="color:var(--muted); font-size:0.875rem; max-width:200px;">
                                @(string.IsNullOrWhiteSpace(assignment.Description) ? "-" : (assignment.Description.Length > 60 ? assignment.Description.Substring(0, 60) + "..." : assignment.Description))
                            </td>
                            <td style="font-size:0.875rem; color: @(isOverdue ? "var(--danger)" : "var(--muted)")">
                                @assignment.DueDate.ToLocalTime().ToString("MMM dd, yyyy")
                            </td>
                            <td>
                                @if (role == "Teacher")
                                {
                                    <span class="badge badge-green">Active</span>
                                }
                                else if (submitted)
                                {
                                    <span class="badge badge-green">Submitted</span>
                                }
                                else if (isOverdue)
                                {
                                    <span class="badge badge-red">Overdue</span>
                                }
                                else
                                {
                                    <span class="badge badge-orange">Pending</span>
                                }
                            </td>
                            <td>
                                @if (role == "Teacher")
                                {
                                    <a href="/Submission/ViewSubmissions/@assignment.AssignmentId" class="btn btn-outline btn-sm">View Submissions</a>
                                    <a href="/Assignment/DeleteAssignment/@assignment.AssignmentId"
                                       class="btn btn-danger btn-sm"
                                       onclick="return confirm('Delete this assignment?')">Delete</a>
                                }
                                else if (!submitted)
                                {
                                    <a href="/Submission/SubmitAssignment/@assignment.AssignmentId" class="btn btn-success btn-sm">Submit</a>
                                }
                                else
                                {
                                    <span style="color:var(--muted); font-size:0.8rem;">Done</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>